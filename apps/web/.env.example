# Supabase - get from https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic Claude API - get from https://console.anthropic.com
# IMPORTANT: This is server-side only, never expose to client
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# LOG_LEVEL=debug|info|warn|error  (default: debug in dev, warn in prod)
LOG_LEVEL=debug

# cache needs this
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# E2E tests - a dedicated test account in your Supabase project
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=your_test_password

# Sentry - get from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# Optional: for source map uploads during build
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your_org_slug
# SENTRY_PROJECT=your_project_slug
